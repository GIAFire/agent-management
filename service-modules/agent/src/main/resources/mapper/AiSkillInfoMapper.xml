<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zw.agent.mapper.AiSkillInfoMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zw.agent.entity.AiSkillInfoEntity">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="description" property="description" />
        <result column="skill_content" property="skillContent" />
        <result column="source" property="source" />
        <result column="risk_level" property="riskLevel" />
        <result column="requires_shell" property="requiresShell" />
        <result column="requires_sandbox" property="requiresSandbox" />
        <result column="tags_json" property="tagsJson" />
        <result column="status" property="status" />
    </resultMap>

    <resultMap id="SkillFileMap" type="com.zw.agent.entity.DTO.SkillFileDTO">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="description" property="description" />
        <result column="skill_content" property="skillContent" />
        <result column="source" property="source" />
        <result column="risk_level" property="riskLevel" />
        <result column="requires_shell" property="requiresShell" />
        <result column="requires_sandbox" property="requiresSandbox" />
        <result column="tags_json" property="tagsJson" />
        <result column="status" property="status" />
        <collection property="skillFileList" ofType="com.zw.agent.entity.DTO.FileDTO">
            <id property="id" column="file_id"/>
            <result property="skillId" column="skill_id"/>
            <result property="fileRole" column="file_role"/>
            <result property="fileName" column="file_name"/>
            <result property="resourcePath" column="resource_path"/>
            <result property="resourceContent" column="resource_content"/>
            <result property="storageKey" column="storage_key"/>
            <result property="workspaceFileId" column="workspace_file_id"/>
        </collection>
    </resultMap>

    <select id="getAgentSkill" resultMap="SkillFileMap" parameterType="String">
        SELECT
            si.id,
            si.NAME,
            si.description,
            si.skill_content,
            si.source,
            sf.id file_id,
            sf.skill_id skill_id,
            sf.file_role,
            sf.file_name,
            sf.resource_path,
            sf.resource_content,
            sf.storage_key,
            sf.workspace_file_id
        FROM
            ai_skill_info si
                LEFT JOIN ai_skill_file sf ON si.id = sf.skill_id
                LEFT JOIN ai_skill_agent_binding sab ON sab.skill_id = si.id
        WHERE
            si.NAME = #{name}
            sab.agent_id = #{agentId}
    </select>

    <select id="getAgentSkillName" resultMap="SkillFileMap">
        SELECT
            si.id,
            si.NAME,
            si.description,
            si.skill_content,
            si.source,
            sf.id file_id,
            sf.skill_id skill_id,
            sf.file_role,
            sf.file_name,
            sf.resource_path,
            sf.resource_content,
            sf.storage_key,
            sf.workspace_file_id
        FROM
            ai_skill_info si
                LEFT JOIN ai_skill_file sf ON si.id = sf.skill_id
                LEFT JOIN ai_skill_agent_binding sab ON sab.skill_id = si.id
        WHERE
            sab.agent_id = #{agentId}
    </select>

</mapper>
