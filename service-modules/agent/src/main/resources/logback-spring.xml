<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
        日志根目录
        ${user.dir} 表示项目启动目录：
        1. IDEA 启动时，通常是项目根目录
        2. java -jar 启动时，是执行 java -jar 命令所在的目录
        这里日志会输出到：
        项目根路径/logs/
    -->
    <property name="LOG_HOME" value="${user.dir}/service-modules/agent/logs"/>

    <!-- 普通业务日志格式：文件输出使用，不带颜色，避免 ANSI 控制字符写入文件 -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [tenantId=%X{tenantId} userId=%X{userId} sessionId=%X{sessionId}] %logger{36} - %msg%n"/>

    <!-- 控制台日志格式：按日志级别高亮，ERROR 通常为红色，WARN 通常为黄色 -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%highlight(%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [tenantId=%X{tenantId} userId=%X{userId} sessionId=%X{sessionId}] %logger{36} - %msg%n)"/>

    <!-- SQL 日志格式：只输出 MyBatis 原始日志内容 -->
    <property name="SQL_PATTERN" value="%msg%n"/>

    <!-- 控制台输出：普通业务日志，带颜色 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 错误日志文件输出：只额外保存 ERROR 及以上级别日志 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/AgentApplication-error-%d{yyyy-MM-dd}.txt</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 文件输出：普通业务日志，按天生成 txt 文件 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/AgentApplication-%d{yyyy-MM-dd}.txt</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 接口调用日志 -->
    <logger name="com.zw.common.filter.ApiLogFilter" level="INFO"/>

    <!-- 控制台输出：SQL 日志，只输出 msg -->
    <appender name="SQL_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${SQL_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- MyBatis Mapper SQL 日志 -->
    <logger name="com.zw.agent.mapper" level="DEBUG" additivity="false">
        <appender-ref ref="SQL_CONSOLE"/>
    </logger>

    <!-- MyBatis 框架日志 -->
    <logger name="org.apache.ibatis" level="INFO"/>

    <!-- JDBC 日志 -->
    <logger name="java.sql" level="INFO"/>

    <!-- Spring HTTP 客户端相关日志 -->
    <logger name="org.springframework.web.client" level="DEBUG"/>

    <!-- OpenAI SDK 相关日志 -->
    <logger name="com.openai" level="DEBUG"/>

    <!-- 根日志配置 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>
</configuration>