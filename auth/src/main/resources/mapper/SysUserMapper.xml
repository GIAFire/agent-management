<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zw.auth.mapper.SysUserMapper">

    <resultMap id="UserInfoResultMap" type="com.zw.auth.entity.DTO.UserInfoDTO">
        <id property="id" column="id"/>
        <result property="userName" column="user_name"/>
        <result property="password" column="password"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="status" column="status"/>
        <collection property="roleCodes" ofType="string">
            <result column="role_code"/>
        </collection>
    </resultMap>

    <select id="login" resultMap="UserInfoResultMap" parameterType="String">
        SELECT
            u.id,
            u.user_name,
            u.password,
            u.tenant_id,
            r.role_code,
            u.status
        FROM
            sys_user u
                LEFT JOIN sys_user_role ur ON u.id = ur.user_id
                LEFT JOIN sys_role r ON r.id = ur.role_id
        WHERE u.status = 1
          AND u.user_name = #{userName}
          AND u.password = #{password}
    </select>

</mapper>
